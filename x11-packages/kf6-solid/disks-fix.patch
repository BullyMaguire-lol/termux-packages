 void Solid::Backends::Fstab::FstabHandling::_k_updateMtabMountPointsCache()
 {
+#ifdef __TERMUX__
+
+    if (globalFstabCache->localData().m_mtabCacheValid) {
+        return;
+    }
+
+    globalFstabCache->localData().m_mtabCache.clear();
+    globalFstabCache->localData().m_mtabOptionsCache.clear();
+    globalFstabCache->localData().m_fstabFstypeCache.clear();
+
+    QFile file(QStringLiteral("/proc/self/mountinfo"));
+    if (!file.open(QIODevice::ReadOnly | QIODevice::Text)) {
+        qWarning() << "Failed to open mountinfo";
+        return;
+    }
+
+    QTextStream in(&file);
+
+    while (!in.atEnd()) {
+        QString line = in.readLine();
+        QStringList parts = line.split(QLatin1Char(' '));
+
+        int sep = parts.indexOf(QStringLiteral("-"));
+        if (sep == -1 || parts.size() < sep + 3)
+            continue;
+
+        QString mountPoint = parts[4];
+        QString fsType     = parts[sep + 1];
+        QString source     = parts[sep + 2];
+
+        if (!(mountPoint == QStringLiteral("/data") ||
+              mountPoint.startsWith(QStringLiteral("/storage"))))
+            continue;
+
+        QString device = _k_deviceNameForMountpoint(source, fsType, mountPoint);
+
+        globalFstabCache->localData().m_mtabCache.insert(device, mountPoint);
+        globalFstabCache->localData().m_fstabFstypeCache.insert(device, fsType);
+    }
+
+    globalFstabCache->localData().m_mtabCacheValid = true;
+
+#else
     if (globalFstabCache->localData().m_mtabCacheValid) {
         return;
     }
