+#ifdef __TERMUX__
+void LinuxCpuPluginPrivate::updateFromCpuIdle()
+{
+    static QVector<long long> prevIdle;
+    static qint64 prevTime = 0;
+
+    const int cpuCount = m_cpus.size();
+    if (cpuCount == 0)
+        return;
+
+    if (prevIdle.size() != cpuCount)
+        prevIdle.resize(cpuCount);
+
+    const qint64 now = QDateTime::currentMSecsSinceEpoch();
+    if (prevTime == 0) {
+        prevTime = now;
+        return;
+    }
+
+    const double elapsedSec = (now - prevTime) / 1000.0;
+    prevTime = now;
+
+    long long totalIdleDelta = 0;
+
+    for (int i = 0; i < cpuCount; ++i) {
+        const QString basePath =
+            QStringLiteral("/sys/devices/system/cpu/cpu%1/cpuidle/").arg(i);
+
+        QDir dir(basePath);
+        if (!dir.exists())
+            continue;
+
+        long long idleSum = 0;
+
+        const auto states = dir.entryList(QDir::Dirs | QDir::NoDotAndDotDot);
+        for (const QString &state : states) {
+            QFile f(basePath + state + QStringLiteral("/time"));
+            if (f.open(QIODevice::ReadOnly)) {
+                idleSum += f.readAll().trimmed().toLongLong();
+            }
+        }
+
+        const long long delta = idleSum - prevIdle[i];
+        prevIdle[i] = idleSum;
+
+        totalIdleDelta += delta;
+    }
+
+    // cpuidle time is typically in microseconds
+    const double totalTime = elapsedSec * cpuCount * 1000000.0;
+    if (totalTime <= 0)
+        return;
+
+    double usage = 1.0 - (totalIdleDelta / totalTime);
+    usage = std::clamp(usage, 0.0, 1.0);
+
+    // simple smoothing for UI stability
+    static double prevUsage = 0.0;
+    usage = prevUsage * 0.7 + usage * 0.3;
+    prevUsage = usage;
+
+    const long long active = usage * 100.0;
+    const long long idle = (1.0 - usage) * 100.0;
+
+    m_allCpus->update(active, 0, 0, idle);
+
+    for (auto cpu : std::as_const(m_cpus)) {
+        cpu->update(active, 0, 0, idle);
+    }
+}
+#endif
 
