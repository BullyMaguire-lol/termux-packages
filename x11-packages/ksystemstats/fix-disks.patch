+#ifdef __TERMUX__
+class VolumeObject : public KSysGuard::SensorObject
+{
+    Q_OBJECT
+
+public:
+    VolumeObject(const QString &mountPoint, KSysGuard::SensorContainer *parent)
+        : SensorObject(
+            QString("disk/") + mountPoint.mid(1).replace(QLatin1Char('/'), QLatin1Char('_')),
+            mountPoint,
+            parent
+          ),
+          mountPoint(mountPoint)
+    {
+        m_total = new KSysGuard::SensorProperty("total", "Total", this);
+        m_total->setUnit(KSysGuard::UnitByte);
+        m_total->setVariantType(QVariant::ULongLong);
+
+        m_used  = new KSysGuard::SensorProperty("used", "Used", this);
+        m_used->setUnit(KSysGuard::UnitByte);
+        m_used->setVariantType(QVariant::ULongLong);
+
+        m_free  = new KSysGuard::SensorProperty("free", "Free", this);
+        m_free->setUnit(KSysGuard::UnitByte);
+        m_free->setVariantType(QVariant::ULongLong);
+
+        auto usedPercent = new KSysGuard::PercentageSensor(this, "usedPercent", i18nc("@title", "Used %"));
+        usedPercent->setBaseSensor(m_used);
+
+        auto freePercent = new KSysGuard::PercentageSensor(this, "freePercent", i18nc("@title", "Free %"));
+        freePercent->setBaseSensor(m_free);
+    }
+
+    void update()
+    {
+        struct statvfs stat;
+        if (statvfs(mountPoint.toUtf8().constData(), &stat) != 0)
+            return;
+
+        quint64 total = stat.f_blocks * stat.f_frsize;
+        quint64 free  = stat.f_bavail * stat.f_frsize;
+        quint64 used  = total - free;
+
+        m_total->setValue(total);
+
+        m_free->setValue(free);
+        m_free->setMax(total);
+
+        m_used->setValue(used);
+        m_used->setMax(total);
+    }
+
+    bool isRootDevice() const { return false; }
+
+    const QString mountPoint;
+
+private:
+    KSysGuard::SensorProperty *m_total;
+    KSysGuard::SensorProperty *m_used;
+    KSysGuard::SensorProperty *m_free;
+};
+#endif
 
